<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.controller.LoginController" styleClass="app-root auth-root">
    <padding>
        <Insets top="26.0" right="26.0" bottom="26.0" left="26.0"/>
    </padding>

    <VBox spacing="16.0" styleClass="card auth-card" maxWidth="520.0">
        <padding>
            <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
        </padding>

        <HBox spacing="8.0">
            <FontIcon iconLiteral="fas-lock" iconSize="16" iconColor="#5A6CFF"/>
            <Label text="CONNEXION" styleClass="auth-kicker"/>
        </HBox>
        <Label text="Bienvenue" styleClass="subtitle-text auth-subtitle"/>
        <Label text="Accedez a votre espace de discussion interne" styleClass="caption-text"/>

        <GridPane hgap="10.0" vgap="10.0">
            <Label text="Nom d'utilisateur:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="champNomUtilisateur" promptText="Nom d'utilisateur" styleClass="input-field"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Mot de passe:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="champMotDePasse" promptText="Mot de passe" styleClass="input-field"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="10.0">
            <Button text="SE CONNECTER" styleClass="primary-button" onAction="#seConnecterAuServeur">
                <graphic>
                    <FontIcon iconLiteral="fas-sign-in-alt" iconSize="13" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="S'INSCRIRE" styleClass="ghost-button" onAction="#allerVersEcranInscription">
                <graphic>
                    <FontIcon iconLiteral="fas-user-plus" iconSize="12" iconColor="#4A5690"/>
                </graphic>
            </Button>
            <Button text="RETOUR" styleClass="ghost-button" onAction="#retourVersEcranAccueil">
                <graphic>
                    <FontIcon iconLiteral="fas-arrow-left" iconSize="12" iconColor="#4A5690"/>
                </graphic>
            </Button>
        </HBox>

        <HBox spacing="8.0">
            <Button fx:id="boutonTheme" text="Mode sombre" styleClass="top-action-button theme-button" onAction="#basculerEntreThemeClairEtSombre">
                <graphic>
                    <FontIcon iconLiteral="fas-moon" iconSize="12" iconColor="white"/>
                </graphic>
            </Button>
            <Label fx:id="labelRetour" styleClass="caption-text"/>
        </HBox>
    </VBox>
</VBox>

